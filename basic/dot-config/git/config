[core]
	editor = nvim
	whitespace = space-before-tab,trailing-space
	preloadindex = true
	excludesfile = ~/.config/git/gitignore
[init]
	defaultBranch = main
[color]
	status = auto
	branch = auto
	interactive = auto
	diff = auto
[diff]
	tool = nvimdiff
	renames = copies
	interHunkContext = 10
	alogrithm = histogram
[pull]
	ff = true
[push]
	default = current
[merge]
	conflictstyle = zdiff3
	tool = nvimdiff
	prompt = false
[mergetool]
	keepBackup = false
[mergetool "nvimdiff"]
	layout = LOCAL,BASE,REMOTE / MERGED
[rebase]
	autoStash = true
	autoSquash = true
	missingCommitsCheck = warn
[status]
	showStash = true
	branch = true
	showUntrackedFiles = all
[branch]
	sort = -committerdate
[tag]
	sort = -taggerdate
[stash]
	showIncludeUntracked = true
[rerere]
	enabled = true
[gc]
	auto = 3000
[color.decorate]
	HEAD = 183 bold
	branch = 70
	remoteBranch = 220
	tag = 208
	stash = 127
[grep]
	lineNumber = true
	patternType = perl
[transfer]
	fsckobjects = true
[fetch]
	fsckobjects = true
[receive]
	fsckObjects = true
[url "git@github.com:"]
	pushInsteadOf = "https://github.com/"
[alias]
	pom = pull origin main
	lol = log --oneline --decorate --pretty=format:'%C(auto)%h %C(blue)%as %C(auto)%s%C(green)%d'
	graph = log --oneline --graph --decorate
	history = reflog --date=iso --pretty
	wdiff = diff --word-diff
	mdiff = diff -w -U0 --minimal --output-indicator-new=' ' --output-indicator-old=' '
	smartblame = blame -C -C -C
	hh = rev-parse HEAD
	hash = rev-parse --verify
	ap = add --patch

[checkout]
	defaultRemote = origin
